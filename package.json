{
  "name": "tokens",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "tokens": "./src/index.ts",
    "tokens-statusline": "./src/statusline.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "check": "tsc --noEmit && bun run lint",
    "install:specs": "bun build src/specs/*.ts --outdir ~/.fig/autocomplete/build --minify --format esm",
    "build": "bun build src/index.ts --target bun --outdir ./out"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "latest",
    "@withfig/autocomplete-types": "1.31.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
